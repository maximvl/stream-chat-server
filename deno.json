{
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-env --allow-read --allow-ffi src/main.ts",
    "start": "deno run --allow-net --allow-env --allow-read --allow-sys --allow-ffi src/main.ts",
    "test": "deno test --allow-env --allow-read",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "check": "deno check **/*.ts",
    "generate": "deno run -A npm:drizzle-kit generate",
    "migrate": "deno run -A npm:drizzle-kit migrate"
  },
  "compilerOptions": {
    "strict": true
  },
  "fmt": {
    "semiColons": false,
    "singleQuote": true
  },
  "imports": {
    "@libsql/client": "npm:@libsql/client@^0.17.4",
    "@std/assert": "jsr:@std/assert@1",
    "@std/dotenv": "jsr:@std/dotenv@0.225.7",
    "arktype": "npm:arktype@^2.2.2",
    "cheerio": "npm:cheerio@^1.2.0",
    "drizzle-kit": "npm:drizzle-kit@^0.31.10",
    "drizzle-orm": "npm:drizzle-orm@^0.45.2"
  }
}
